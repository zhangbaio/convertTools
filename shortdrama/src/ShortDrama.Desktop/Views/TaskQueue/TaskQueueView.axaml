<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:taskqueue="using:ShortDrama.Desktop.Views.TaskQueue"
             x:Class="ShortDrama.Desktop.Views.TaskQueue.TaskQueueView">
    <Grid>
        <taskqueue:TaskQueueOverviewView IsVisible="{Binding IsTaskQueueOverviewVisible}" />
        <taskqueue:TaskQueueDetailView IsVisible="{Binding HasTaskQueueDetail}" />
    </Grid>
</UserControl>
