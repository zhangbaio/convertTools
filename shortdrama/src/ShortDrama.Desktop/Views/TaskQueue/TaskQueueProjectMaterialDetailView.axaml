<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ShortDrama.Desktop.Views.TaskQueue.TaskQueueProjectMaterialDetailView">
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding SelectedProject.DisplayName}" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SelectedProject.ProjectMaterialNodeStatus}"
                           Foreground="{Binding SelectedProject.ProjectMaterialNodeForegroundBrush}" />
            </StackPanel>
            <Button Grid.Column="1"
                    MinWidth="130"
                    Command="{Binding StopCurrentRunCommand}"
                    Content="停止当前步骤" />
        </Grid>

        <WrapPanel Grid.Row="1" ItemWidth="140" Orientation="Horizontal">
            <Button MinWidth="130" Margin="0,0,10,0" Command="{Binding RunSelectedTranscodeCommand}" Content="只执行转码" />
            <Button MinWidth="140" Margin="0,0,10,0" Click="RunSelectedRewriteDetail_Click" Content="改写信息" />
            <Button MinWidth="140" Margin="0,0,10,0" Click="RunSelectedPosterDetail_Click" Content="生成海报" />
            <Button MinWidth="130" Margin="0,0,10,0" Click="RunSelectedProjectImageDetail_Click" Content="生成工程图" />
            <Button MinWidth="140" Margin="0,0,10,0" Click="RunSelectedCostReportDetail_Click" Content="生成成本报表" />
            <Button MinWidth="150" Margin="0,0,10,0" Click="RunSelectedBatchRenameDetail_Click" Content="重命名视频文件" />
            <Button MinWidth="150" Margin="0,0,10,0" Click="RunSelectedMaterialConvertDetail_Click" Content="转换素材视频" />
            <Button MinWidth="140" Margin="0,0,10,0" Click="RenameSelectedProjectTitle_Click" Content="修改新剧名" />
            <Button MinWidth="130" Margin="0,0,10,0" Command="{Binding ValidateSelectedProjectMaterialCommand}" Content="素材校验" />
            <Button MinWidth="130" Margin="0,0,10,0" Click="FixAllMaterialValidationIssues_Click" Content="一键修复" />
            <Button MinWidth="170" Margin="0,0,10,0" Command="{Binding RunSelectedProjectMaterialCommand}" Content="一键生成项目素材" />
        </WrapPanel>

        <Grid Grid.Row="2" MinHeight="0" ColumnDefinitions="0.9*,1.1*" ColumnSpacing="12">
            <Border Background="{DynamicResource DesktopPanelBrush}" CornerRadius="14" Padding="12">
                <Grid RowDefinitions="Auto,*" RowSpacing="8">
                    <TextBlock Text="项目素材步骤" FontSize="18" FontWeight="SemiBold" />
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding ProjectMaterialSteps}"
                             SelectedItem="{Binding SelectedProjectMaterialStep}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="8"
                                        CornerRadius="12"
                                        Background="{Binding BackgroundBrush}">
                                    <Grid ColumnDefinitions="44,*">
                                        <StackPanel Spacing="0" HorizontalAlignment="Center">
                                            <Border Width="36"
                                                    Height="36"
                                                    CornerRadius="18"
                                                    BorderThickness="3"
                                                    BorderBrush="{Binding AccentBrush}"
                                                    Background="Transparent">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding Index}"
                                                           FontWeight="Bold"
                                                           Foreground="{Binding AccentBrush}" />
                                            </Border>
                                            <Border Width="3"
                                                    Height="42"
                                                    IsVisible="{Binding ShowConnector}"
                                                    Background="{Binding SummaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding TitleBrush}" />
                                            <TextBlock Text="{Binding Summary}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{Binding SummaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="1" MinHeight="0" RowDefinitions="Auto,Auto,*" RowSpacing="12">
                <Border Background="{DynamicResource DesktopPanelBrush}" CornerRadius="14" Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="当前步骤" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedProjectMaterialStep.Label}" />
                        <TextBlock Text="{Binding SelectedProjectMaterialStep.Status}"
                                   Foreground="{Binding SelectedProjectMaterialStep.TitleBrush}" />
                        <TextBlock Text="{Binding SelectedProjectMaterialStep.Summary}"
                                   Foreground="{DynamicResource DesktopTextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="{DynamicResource DesktopPanelBrush}" CornerRadius="14" Padding="12">
                    <Grid RowDefinitions="Auto,*" RowSpacing="8">
                        <TextBlock Text="素材校验结果" FontSize="18" FontWeight="SemiBold" />
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding MaterialValidationIssues}"
                                 MaxHeight="170"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            CornerRadius="12"
                                            Background="{DynamicResource DesktopPanelAltBrush}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Severity}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="修复"
                                                    IsEnabled="{Binding CanAutoFix}"
                                                    Click="FixMaterialValidationIssue_Click" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Row="2" MinHeight="0" Background="{DynamicResource DesktopPanelBrush}" CornerRadius="14" Padding="12">
                    <Grid MinHeight="0" RowDefinitions="Auto,*" RowSpacing="8">
                        <TextBlock Text="当前步骤日志" FontSize="18" FontWeight="SemiBold" />
                        <ListBox Grid.Row="1"
                                 MinHeight="0"
                                 ItemsSource="{Binding ProjectMaterialStepLogs}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            CornerRadius="12"
                                            Background="{DynamicResource DesktopPanelAltBrush}">
                                        <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap" />
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
