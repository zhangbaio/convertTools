<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ShortDrama.Desktop.Views.DeleteArchivedProjectWindow"
        Width="640"
        Height="280"
        MinWidth="560"
        MinHeight="240"
        Title="删除归档项目">

    <Grid RowDefinitions="*,Auto" Margin="20" RowSpacing="16">
        <Border Background="{DynamicResource DesktopPanelBrush}"
                CornerRadius="16"
                Padding="16">
            <StackPanel Spacing="10">
                <TextBlock Text="确认删除当前归档项目？"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding DisplayName}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding ArchiveProjectDir}"
                           Foreground="{DynamicResource DesktopTextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Text="此操作会删除该归档项目下的 source / workflow / backup / archive-meta.json，且不可恢复。"
                           Foreground="IndianRed"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    HorizontalAlignment="Right">
            <Button Content="取消"
                    Click="Cancel_Click" />
            <Button Content="确认删除"
                    Click="Confirm_Click" />
        </StackPanel>
    </Grid>
</Window>
