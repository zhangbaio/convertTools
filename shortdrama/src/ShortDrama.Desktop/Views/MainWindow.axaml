<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ShortDrama.Desktop.ViewModels"
        xmlns:taskqueue="using:ShortDrama.Desktop.Views.TaskQueue"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ShortDrama.Desktop.Views.MainWindow"
        Width="1680"
        Height="980"
        MinWidth="1420"
        MinHeight="860"
        Icon="/Assets/avalonia-logo.ico"
        Title="ShortDrama Desktop">

    <Window.Styles>
        <Style Selector="TabControl.sidebar">
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TabControl.sidebar TabItem">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="MinWidth" Value="220" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource DesktopTextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>
        <Style Selector="TabControl.sidebar TabItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource DesktopPanelAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DesktopTextPrimaryBrush}" />
        </Style>
        <Style Selector="TabControl.sidebar TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource DesktopPanelAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DesktopTextPrimaryBrush}" />
        </Style>
    </Window.Styles>

    <Grid Margin="20">
        <TabControl Classes="sidebar" TabStripPlacement="Left">
            <TabItem Header="鐭墽鎼滅储">
                <Grid RowDefinitions="Auto,*" RowSpacing="16">
                    <Border Background="{DynamicResource DesktopPanelBrush}"
                            CornerRadius="18"
                            Padding="16">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10">
                                <TextBox Grid.Column="0"
                                         Text="{Binding SearchKeyword}"
                                         Watermark="杈撳叆鐭墽鍚嶇О锛屼緥濡?濠嗗﹩銆侀棯濠氥€侀€嗚...">
                                    <TextBox.KeyBindings>
                                        <KeyBinding Gesture="Enter"
                                                    Command="{Binding SearchDramaCommand}" />
                                    </TextBox.KeyBindings>
                                </TextBox>
                                <Button Grid.Column="1"
                                        MinWidth="100"
                                        Command="{Binding SearchDramaCommand}"
                                        Content="鎼滅储" />
                                <Button Grid.Column="2"
                                        MinWidth="110"
                                        Command="{Binding LoadTodayDramaCommand}"
                                        Content="浠婃棩涓婃柊" />
                                <Border Grid.Column="3"
                                        MinWidth="120"
                                        Padding="14,10"
                                        Background="{DynamicResource DesktopPanelAltBrush}"
                                        CornerRadius="12">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="{Binding SearchPageText}" />
                                </Border>
                                <Button Grid.Column="4"
                                        MinWidth="90"
                                        Command="{Binding GoPreviousSearchPageCommand}"
                                        Content="涓婁竴椤?" />
                                <Button Grid.Column="5"
                                        MinWidth="90"
                                        Command="{Binding GoNextSearchPageCommand}"
                                        Content="涓嬩竴椤?" />
                            </Grid>

                            <StackPanel Grid.Row="1" Spacing="12">
                                <Grid ColumnDefinitions="Auto,180,*,Auto" ColumnSpacing="10">
                                    <TextBlock VerticalAlignment="Center"
                                               Text="闆嗘暟鑼冨洿" />
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding DownloadEpisodeRangeOptions}"
                                              SelectedItem="{Binding SelectedDownloadEpisodeRangeOption}"
                                              DisplayMemberBinding="{Binding Label}" />
                                    <TextBox Grid.Column="2"
                                             Text="{Binding CustomDownloadEpisodeRange}"
                                             Watermark="濡傦細1-5 鎴?1,3,5"
                                             IsEnabled="{Binding IsCustomDownloadEpisodeRange}" />
                                    <Button Grid.Column="3"
                                            MinWidth="120"
                                            Command="{Binding DownloadCheckedDramaCommand}"
                                            Content="涓嬭浇閫変腑" />
                                </Grid>

                                <WrapPanel Orientation="Horizontal">
                                <Button MinWidth="150"
                                        Margin="0,0,10,0"
                                        Command="{Binding ImportCheckedDramaCommand}"
                                        Content="鍕鹃€夊鍏ュ伐浣滅洰褰?" />
                                <Button MinWidth="190"
                                        Margin="0,0,10,0"
                                        Command="{Binding ImportAndRunCheckedDramaCommand}"
                                        Content="鍕鹃€夐」鐩竴閿墽琛屽叏娴佺▼" />
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{DynamicResource DesktopPanelBrush}"
                            CornerRadius="18"
                            Padding="16">
                        <StackPanel Spacing="12">
                            <Border Background="{DynamicResource DesktopPanelAltBrush}" CornerRadius="14" Padding="12">
                                <Grid ColumnDefinitions="56,300,90,180,*" ColumnSpacing="12">
                                    <TextBlock Text="鍕鹃€?" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="鍓у悕" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="闆嗘暟" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="3" Text="绫诲瀷" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="4" Text="绠€浠?" FontWeight="SemiBold" />
                                </Grid>
                            </Border>

                            <ListBox ItemsSource="{Binding SearchResults}"
                                     SelectedItem="{Binding SelectedSearchResult}"
                                     MinHeight="420">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12"
                                                CornerRadius="14"
                                                Background="{DynamicResource DesktopPanelAltBrush}">
                                            <Grid ColumnDefinitions="56,300,90,180,*" ColumnSpacing="12">
                                                <CheckBox IsChecked="{Binding IsChecked}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Title}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding EpisodeTotal}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Category}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding Intro}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           MaxLines="2" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                </Grid>
            </TabItem>

            <TabItem Header="任务队列">
                <taskqueue:TaskQueueView />
            </TabItem>

            <TabItem Header="宸插綊妗ｉ」鐩?">
                <Border Background="{DynamicResource DesktopPanelBrush}"
                        CornerRadius="18"
                        Padding="16">
                    <Grid RowDefinitions="Auto,*" RowSpacing="16">
                        <Border Background="{DynamicResource DesktopPanelAltBrush}"
                                CornerRadius="16"
                                Padding="16">
                            <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="12">
                                <Button MinWidth="120"
                                        Command="{Binding RefreshArchivedProjectsCommand}"
                                        Content="鍒锋柊褰掓。鍒楄〃" />
                                <Button Grid.Column="1"
                                        MinWidth="160"
                                        Click="DeleteCheckedArchivedProjects_Click"
                                        Content="鍒犻櫎鍕鹃€夊綊妗ｉ」鐩?" />
                                <Border Grid.Column="2"
                                        MinWidth="150"
                                        Padding="14,10"
                                        Background="{DynamicResource DesktopPanelBrush}"
                                        CornerRadius="12">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="{Binding ArchivedProjects.Count, StringFormat=宸插綊妗? {0}}" />
                                </Border>
                                <TextBlock Grid.Column="3"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Text="{Binding RootDir, StringFormat=褰掓。鏍圭洰褰? {0}/archive}"
                                           Foreground="{DynamicResource DesktopTextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1"
                              RowDefinitions="Auto,*"
                              RowSpacing="12">
                            <Border Background="{DynamicResource DesktopPanelBrush}"
                                    CornerRadius="14"
                                    Padding="12">
                                <Grid ColumnDefinitions="56,240,170,120,120,120,120,100" ColumnSpacing="12">
                                    <TextBlock Text="鍕鹃€?" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="椤圭洰鍚?" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="褰掓。鏃堕棿" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="3" Text="宸插垹瑙嗛" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="4" Text="褰掓。鐩綍" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="5" Text="鍘熼」鐩洰褰?" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="6" Text="鐢熸垚鐩綍" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="7" Text="鍒犻櫎" FontWeight="SemiBold" />
                                </Grid>
                            </Border>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding ArchivedProjects}"
                                     SelectedItem="{Binding SelectedArchivedProject}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12"
                                                CornerRadius="14"
                                                Background="{DynamicResource DesktopPanelAltBrush}">
                                            <Grid ColumnDefinitions="56,240,170,120,120,120,120,100" ColumnSpacing="12">
                                                <CheckBox IsChecked="{Binding IsChecked}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DisplayName}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding ArchivedAtText}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding DeletedVideoFileCount}"
                                                           VerticalAlignment="Center" />
                                                <Button Grid.Column="4"
                                                        Content="鎵撳紑"
                                                        Click="OpenArchivedProjectRow_Click" />
                                                <Button Grid.Column="5"
                                                        Content="鎵撳紑"
                                                        Click="OpenArchivedSourceRow_Click" />
                                                <Button Grid.Column="6"
                                                        Content="鎵撳紑"
                                                        Click="OpenArchivedWorkflowRow_Click" />
                                                <Button Grid.Column="7"
                                                        Content="鍒犻櫎"
                                                        Click="DeleteArchivedProjectRow_Click" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="宸ヤ綔鍙?">
                <Grid ColumnDefinitions="320,*" ColumnSpacing="16">
                    <Border Grid.Column="0"
                            Background="{DynamicResource DesktopPanelBrush}"
                            CornerRadius="18"
                            Padding="16">
                        <Grid RowDefinitions="Auto,*" RowSpacing="12">
                            <TextBlock Text="椤圭洰鍒楄〃" FontSize="20" FontWeight="SemiBold" />
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Projects}"
                                     SelectedItem="{Binding SelectedProject}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ProjectListItemViewModel">
                                        <Border Margin="0,0,0,10" Padding="14" CornerRadius="14" Background="{DynamicResource DesktopPanelAltBrush}">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding SchedulingStatus}"
                                                           Foreground="{Binding SchedulingStatusBrush}" />
                                                <TextBlock Text="{Binding CurrentStepLabel}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding CurrentStepProgressText}"
                                                           Foreground="{DynamicResource DesktopTextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Background="{DynamicResource DesktopPanelBrush}"
                            CornerRadius="18"
                            Padding="20">
                        <ScrollViewer>
                            <StackPanel Spacing="16">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedProjectTitle}" FontSize="24" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding SelectedProject.SchedulingStatus, FallbackValue=璇烽€夋嫨宸︿晶椤圭洰}"
                                               Foreground="{Binding SelectedProject.SchedulingStatusBrush}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding SelectedProject.CurrentStepLabel}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding SelectedProject.CurrentStepProgressText}"
                                               Foreground="{DynamicResource DesktopTextSecondaryBrush}" />
                                </StackPanel>

                                <Border Background="{DynamicResource DesktopPanelAltBrush}" CornerRadius="16" Padding="16">
                                    <Grid ColumnDefinitions="170,*,Auto" ColumnSpacing="12">
                                        <TextBlock VerticalAlignment="Center" Text="鍗曟鎵ц" Foreground="{DynamicResource DesktopTextSecondaryBrush}" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding StepOptions}"
                                                  SelectedItem="{Binding SelectedStepOption}"
                                                  DisplayMemberBinding="{Binding Label}" />
                                        <Button Grid.Column="2"
                                                MinWidth="120"
                                                Command="{Binding RunSelectedStepCommand}"
                                                Content="杩愯褰撳墠姝ラ" />
                                    </Grid>
                                </Border>

                                <WrapPanel ItemWidth="140" Orientation="Horizontal">
                                    <Button MinWidth="130"
                                            Margin="0,0,10,0"
                                            Command="{Binding RunSelectedProjectCommand}"
                                            Content="閲嶆柊鎵ц椤圭洰" />
                                    <Button MinWidth="130"
                                            Margin="0,0,10,0"
                                            Command="{Binding RunSelectedTranscodeCommand}"
                                            Content="鍙墽琛岃浆鐮?" />
                                    <Button MinWidth="170"
                                            Margin="0,0,10,0"
                                            Command="{Binding RunSelectedProjectMaterialCommand}"
                                            Content="涓€閿敓鎴愰」鐩礌鏉?" />
                                    <Button MinWidth="150"
                                            Margin="0,0,10,0"
                                            Command="{Binding RunSelectedWeixinUploadCommand}"
                                            Content="鍙墽琛屼笂浼犲墽闆?" />
                                    <Button MinWidth="150"
                                            Margin="0,0,10,0"
                                            Command="{Binding RunSelectedWeixinMaterialUploadCommand}"
                                            Content="鍙墽琛屼笂浼犵礌鏉?" />
                                    <Button MinWidth="130"
                                            Margin="0,0,10,0"
                                            Command="{Binding StopCurrentRunCommand}"
                                            Content="鍋滄褰撳墠姝ラ" />
                                </WrapPanel>

                                <Border Background="{DynamicResource DesktopPanelAltBrush}" CornerRadius="16" Padding="16">
                                    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
                                        <TextBlock Text="{Binding ActivityTitle}" FontSize="20" FontWeight="SemiBold" />
                                        <Grid Grid.Row="1" ColumnDefinitions="180,180,120,*" ColumnSpacing="10">
                                            <ComboBox ItemsSource="{Binding ProjectLogFilters}"
                                                      SelectedItem="{Binding SelectedProjectLogFilter}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding StepLogFilters}"
                                                      SelectedItem="{Binding SelectedStepLogFilter}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Label}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <CheckBox Grid.Column="2"
                                                      Content="鍙湅澶辫触"
                                                      IsChecked="{Binding OnlyShowFailedLogs}"
                                                      VerticalAlignment="Center" />
                                        </Grid>
                                        <ListBox Grid.Row="2" MaxHeight="220" ItemsSource="{Binding ActivityLog}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8" Padding="10" CornerRadius="12" Background="{DynamicResource DesktopPanelBrush}">
                                                        <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap" />
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="鐜">
                <Border Background="{DynamicResource DesktopPanelBrush}" CornerRadius="18" Padding="18">
                    <Grid RowDefinitions="Auto,*" RowSpacing="14">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="澶栭儴渚濊禆妫€娴?" />
                            <Button Content="鍒锋柊渚濊禆鐘舵€?" Command="{Binding RefreshDependenciesCommand}" />
                            <Button Content="鎵ц渚濊禆娴嬭瘯" Command="{Binding TestDependenciesCommand}" />
                        </StackPanel>

                        <ListBox Grid.Row="1" ItemsSource="{Binding Dependencies}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10" Padding="16" CornerRadius="16" Background="{DynamicResource DesktopPanelAltBrush}">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnDefinitions="160,90,*,170,260" ColumnSpacing="12">
                                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="1" Text="{Binding Source}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Path}"
                                                           Foreground="{DynamicResource DesktopTextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding TestStatus}"
                                                           Foreground="{DynamicResource DesktopSuccessBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding TestMessage}"
                                                           Foreground="{DynamicResource DesktopTextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <TextBlock Text="鎻愮ず" Foreground="{DynamicResource DesktopTextSecondaryBrush}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Hint}"
                                                           Foreground="{DynamicResource DesktopTextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
