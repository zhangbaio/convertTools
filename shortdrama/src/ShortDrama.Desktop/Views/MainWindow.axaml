<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:localviews="using:ShortDrama.Desktop.Views"
        xmlns:taskqueue="using:ShortDrama.Desktop.Views.TaskQueue"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ShortDrama.Desktop.Views.MainWindow"
        Width="1680"
        Height="980"
        MinWidth="1420"
        MinHeight="860"
        Icon="/Assets/avalonia-logo.ico"
        Title="ShortDrama Desktop">

    <Window.Styles>
        <Style Selector="TabControl.sidebar">
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TabControl.sidebar TabItem">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="MinWidth" Value="220" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource DesktopTextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>
        <Style Selector="TabControl.sidebar TabItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource DesktopPanelAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DesktopTextPrimaryBrush}" />
        </Style>
        <Style Selector="TabControl.sidebar TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource DesktopPanelAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DesktopTextPrimaryBrush}" />
        </Style>
    </Window.Styles>

    <Grid Margin="20">
        <TabControl x:Name="SidebarTabs" Classes="sidebar" TabStripPlacement="Left">
            <TabItem Header="短剧搜索">
                <Grid RowDefinitions="Auto,*" RowSpacing="16">
                    <Border Background="{DynamicResource DesktopPanelBrush}"
                            CornerRadius="18"
                            Padding="16">
                        <StackPanel Spacing="14">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <TextBlock VerticalAlignment="Center"
                                           Text="下载目录" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding RootDir}"
                                         IsReadOnly="True" />
                                <Button Grid.Column="2"
                                        MinWidth="130"
                                        Click="PickRootDir_Click"
                                        Content="选择下载目录" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                <TextBox Grid.Column="0"
                                         Text="{Binding SearchKeyword}"
                                         Watermark="输入短剧名称，例如: 婆婆、闪婚、逆袭...">
                                    <TextBox.KeyBindings>
                                        <KeyBinding Gesture="Enter"
                                                    Command="{Binding SearchDramaCommand}" />
                                    </TextBox.KeyBindings>
                                </TextBox>
                                <Button Grid.Column="1"
                                        MinWidth="100"
                                        Command="{Binding SearchDramaCommand}"
                                        Content="搜索" />
                                <CheckBox Grid.Column="2"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding ExactSearchEnabled}"
                                          Content="精确搜索" />
                            </Grid>

                            <WrapPanel Orientation="Horizontal">
                                <Button MinWidth="110"
                                        Margin="0,0,10,10"
                                        Command="{Binding LoadTodayDramaCommand}"
                                        Content="今日上新" />
                                <Button MinWidth="110"
                                        Margin="0,0,10,10"
                                        Command="{Binding LoadMangaTodayDramaCommand}"
                                        Content="漫剧上新" />
                                <Button MinWidth="120"
                                        Margin="0,0,10,10"
                                        Command="{Binding LoadAiTodayDramaCommand}"
                                        Content="AI短剧上新" />
                                <Button MinWidth="110"
                                        Margin="0,0,10,10"
                                        Command="{Binding LoadHistoryDramaCommand}"
                                        Content="历史上新" />
                                <Border Margin="0,0,10,10"
                                        Padding="12,10"
                                        Background="{DynamicResource DesktopPanelAltBrush}"
                                        CornerRadius="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="查询天数" />
                                        <TextBox Width="60"
                                                 Text="{Binding SearchQueryDays}" />
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="天" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,10,10"
                                        MinWidth="120"
                                        Padding="14,10"
                                        Background="{DynamicResource DesktopPanelAltBrush}"
                                        CornerRadius="12">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="{Binding SearchPageText}" />
                                </Border>
                                <Button MinWidth="90"
                                        Margin="0,0,10,10"
                                        Command="{Binding GoPreviousSearchPageCommand}"
                                        Content="上一页" />
                                <Button MinWidth="90"
                                        Margin="0,0,10,10"
                                        Command="{Binding GoNextSearchPageCommand}"
                                        Content="下一页" />
                            </WrapPanel>

                            <Grid ColumnDefinitions="Auto,100,Auto,100,Auto" ColumnSpacing="10">
                                <TextBlock VerticalAlignment="Center"
                                           Text="最小集数" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding SearchMinEpisodeCount}"
                                         Watermark="不限" />
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Text="最大集数" />
                                <TextBox Grid.Column="3"
                                         Text="{Binding SearchMaxEpisodeCount}"
                                         Watermark="不限" />
                                <Button Grid.Column="4"
                                        MinWidth="120"
                                        Command="{Binding ApplySearchFiltersCommand}"
                                        Content="应用筛选" />
                            </Grid>

                            <Grid ColumnDefinitions="Auto,180,*,Auto" ColumnSpacing="10">
                                <TextBlock VerticalAlignment="Center"
                                           Text="集数范围" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding DownloadEpisodeRangeOptions}"
                                          SelectedItem="{Binding SelectedDownloadEpisodeRangeOption}"
                                          DisplayMemberBinding="{Binding Label}" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding CustomDownloadEpisodeRange}"
                                         Watermark="如：1-5 或 1,3,5"
                                         IsEnabled="{Binding IsCustomDownloadEpisodeRange}" />
                                <Button Grid.Column="3"
                                        MinWidth="120"
                                        Command="{Binding DownloadCheckedDramaCommand}"
                                        Content="下载选中" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Border Background="{DynamicResource DesktopPanelAltBrush}"
                                        CornerRadius="14"
                                        Padding="12">
                                    <TextBlock Text="{Binding SearchSummary}"
                                               TextWrapping="Wrap" />
                                </Border>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource DesktopPanelAltBrush}"
                                        CornerRadius="14"
                                        Padding="14,12">
                                    <TextBlock Text="{Binding CheckedSearchResultsSummary}" />
                                </Border>
                            </Grid>

                            <WrapPanel Orientation="Horizontal">
                                <Button MinWidth="150"
                                        Margin="0,0,10,0"
                                        Command="{Binding ImportCheckedDramaCommand}"
                                        Content="勾选导入工作目录" />
                                <Button MinWidth="190"
                                        Margin="0,0,10,0"
                                        Command="{Binding ImportAndRunCheckedDramaCommand}"
                                        Content="勾选项目一键执行全流程" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{DynamicResource DesktopPanelBrush}"
                            CornerRadius="18"
                            Padding="16">
                        <StackPanel Spacing="12">
                            <Border Background="{DynamicResource DesktopPanelAltBrush}" CornerRadius="14" Padding="12">
                                <Grid ColumnDefinitions="64,2.2*,1.2*,90,110,120,150,2.8*" ColumnSpacing="12">
                                    <TextBlock Text="勾选" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="剧名" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="作者" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="3" Text="集数" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="4" Text="收藏量" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="5" Text="类型" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="6" Text="上线时间" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="7" Text="简介" FontWeight="SemiBold" />
                                </Grid>
                            </Border>

                            <ListBox ItemsSource="{Binding SearchResults}"
                                     SelectedItem="{Binding SelectedSearchResult}"
                                     MinHeight="420">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12"
                                                CornerRadius="14"
                                                Background="{DynamicResource DesktopPanelAltBrush}">
                                            <Grid ColumnDefinitions="64,2.2*,1.2*,90,110,120,150,2.8*" ColumnSpacing="12">
                                                <CheckBox IsChecked="{Binding IsChecked}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Title}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Author}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding EpisodeTotal}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding FavoriteCountText}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="5"
                                                           Text="{Binding Category}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="6"
                                                           Text="{Binding PublishTime}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="7"
                                                           Text="{Binding Intro}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           MaxLines="2" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                </Grid>
            </TabItem>

            <TabItem Header="配置">
                <localviews:ConfigView />
            </TabItem>

            <TabItem Header="素材上传">
                <localviews:MaterialUploadView />
            </TabItem>

            <TabItem Header="任务队列">
                <taskqueue:TaskQueueView />
            </TabItem>

            <TabItem Header="运行日志">
                <taskqueue:TaskQueueRunLogView />
            </TabItem>

            <TabItem Header="转码模板">
                <localviews:TranscodeTemplateView />
            </TabItem>

            <TabItem Header="已归档项目">
                <Border Background="{DynamicResource DesktopPanelBrush}"
                        CornerRadius="18"
                        Padding="16">
                    <Grid RowDefinitions="Auto,*" RowSpacing="16">
                        <Border Background="{DynamicResource DesktopPanelAltBrush}"
                                CornerRadius="16"
                                Padding="16">
                            <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="12">
                                <Button MinWidth="120"
                                        Command="{Binding RefreshArchivedProjectsCommand}"
                                        Content="刷新归档列表" />
                                <Button Grid.Column="1"
                                        MinWidth="160"
                                        Click="DeleteCheckedArchivedProjects_Click"
                                        Content="删除勾选归档项目" />
                                <Border Grid.Column="2"
                                        MinWidth="150"
                                        Padding="14,10"
                                        Background="{DynamicResource DesktopPanelBrush}"
                                        CornerRadius="12">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="{Binding ArchivedProjects.Count, StringFormat=已归档 {0}}" />
                                </Border>
                                <TextBlock Grid.Column="3"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Text="{Binding RootDir, StringFormat=归档根目录: {0}/archive}"
                                           Foreground="{DynamicResource DesktopTextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1"
                              RowDefinitions="Auto,*"
                              RowSpacing="12">
                            <Border Background="{DynamicResource DesktopPanelBrush}"
                                    CornerRadius="14"
                                    Padding="12">
                                <Grid ColumnDefinitions="56,240,170,120,120,120,120,100" ColumnSpacing="12">
                                    <TextBlock Text="勾选" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="项目名" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="归档时间" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="3" Text="已删视频" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="4" Text="归档目录" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="5" Text="原项目目录" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="6" Text="生成目录" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="7" Text="删除" FontWeight="SemiBold" />
                                </Grid>
                            </Border>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding ArchivedProjects}"
                                     SelectedItem="{Binding SelectedArchivedProject}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12"
                                                CornerRadius="14"
                                                Background="{DynamicResource DesktopPanelAltBrush}">
                                            <Grid ColumnDefinitions="56,240,170,120,120,120,120,100" ColumnSpacing="12">
                                                <CheckBox IsChecked="{Binding IsChecked}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DisplayName}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding ArchivedAtText}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding DeletedVideoFileCount}"
                                                           VerticalAlignment="Center" />
                                                <Button Grid.Column="4"
                                                        Content="打开"
                                                        Click="OpenArchivedProjectRow_Click" />
                                                <Button Grid.Column="5"
                                                        Content="打开"
                                                        Click="OpenArchivedSourceRow_Click" />
                                                <Button Grid.Column="6"
                                                        Content="打开"
                                                        Click="OpenArchivedWorkflowRow_Click" />
                                                <Button Grid.Column="7"
                                                        Content="删除"
                                                        Click="DeleteArchivedProjectRow_Click" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
