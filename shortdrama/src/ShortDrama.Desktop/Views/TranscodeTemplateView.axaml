<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shapes="using:Avalonia.Controls.Shapes"
             x:Class="ShortDrama.Desktop.Views.TranscodeTemplateView">
    <ScrollViewer>
        <StackPanel Margin="16" Spacing="16">
            <Border Background="{DynamicResource DesktopPanelBrush}" CornerRadius="18" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="转码模板"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="迁移素材转码参数与分辨率码率档位。以下配置主要作用于竖屏模板；横屏视频默认仍走普通转码，但会应用中心放大，不套用背景虚化。"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource DesktopTextSecondaryBrush}" />
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="10">
                        <CheckBox x:Name="MaterialConvertEnabledCheckBox"
                                  Content="启用素材转码"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Name="ConfigPathTextBlock"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource DesktopTextSecondaryBrush}" />
                        <Button Grid.Column="2"
                                x:Name="ReloadButton"
                                Content="重新加载" />
                        <Button Grid.Column="3"
                                x:Name="ResetProfilesButton"
                                Content="恢复默认档位" />
                        <Button Grid.Column="4"
                                x:Name="SaveButton"
                                Content="保存配置" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource DesktopPanelBrush}" CornerRadius="18" Padding="16">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="20" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                    <TextBlock Text="视频编码器" VerticalAlignment="Center" />
                    <ComboBox x:Name="VideoEncoderComboBox"
                              Grid.Column="1"
                              HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="1" Text="编码 preset" VerticalAlignment="Center" />
                    <ComboBox x:Name="VideoPresetComboBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="2" Text="NVENC CQ" VerticalAlignment="Center" />
                    <TextBox x:Name="NvencCqTextBox"
                             Grid.Row="2"
                             Grid.Column="1" />

                    <TextBlock Grid.Row="3" Text="NVENC 并发" VerticalAlignment="Center" />
                    <TextBox x:Name="NvencMaxParallelTextBox"
                             Grid.Row="3"
                             Grid.Column="1" />

                    <CheckBox x:Name="VerboseTranscodeLogCheckBox"
                              Grid.Row="4"
                              Content="输出详细转码日志" />
                    <CheckBox x:Name="SkipBitrateDownscaleCheckBox"
                              Grid.Row="4"
                              Grid.Column="1"
                              Content="高码率视频不主动降码率" />

                    <TextBlock Grid.Row="5" Text="工程说明" VerticalAlignment="Top" />
                    <TextBlock Grid.Row="5"
                               Grid.Column="1"
                               Text="目标/最大/最低码率为全局策略，分辨率档位决定不同短边视频默认套用的目标视频码率与音频码率。"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource DesktopTextSecondaryBrush}" />
                </Grid>
            </Border>

            <Border Background="{DynamicResource DesktopPanelBrush}" CornerRadius="18" Padding="16">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="20" RowDefinitions="Auto,Auto,Auto,Auto">
                    <TextBlock Text="目标码率" VerticalAlignment="Center" />
                    <TextBox x:Name="UploadTargetBitrateTextBox"
                             Grid.Column="1" />

                    <TextBlock Grid.Row="1" Text="最大码率" VerticalAlignment="Center" />
                    <TextBox x:Name="UploadMaxBitrateTextBox"
                             Grid.Row="1"
                             Grid.Column="1" />

                    <TextBlock Grid.Row="2" Text="最低码率" VerticalAlignment="Center" />
                    <TextBox x:Name="UploadMinBitrateTextBox"
                             Grid.Row="2"
                             Grid.Column="1" />

                    <TextBlock Grid.Row="3" Text="音频码率 (kbps)" VerticalAlignment="Center" />
                    <StackPanel Grid.Row="3"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="10">
                        <TextBox x:Name="UploadAudioBitrateTextBox"
                                 Width="160" />
                        <CheckBox x:Name="UploadFallbackEnabledCheckBox"
                                  Content="码率不足时启用兜底重试"
                                  VerticalAlignment="Center" />
                        <TextBox x:Name="UploadFallbackBitrateTextBox"
                                 Width="120" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="{DynamicResource DesktopPanelBrush}" CornerRadius="18" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="分辨率码率档位"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="按源视频短边命中档位。最大短边填 0 表示不设上限。"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource DesktopTextSecondaryBrush}" />

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                        <Border Background="{DynamicResource DesktopPanelAltBrush}" CornerRadius="14" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="720p及以下" FontWeight="SemiBold" />
                                <CheckBox x:Name="Profile720EnabledCheckBox" Content="启用" />
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                    <TextBlock Text="最小短边" VerticalAlignment="Center" />
                                    <TextBox x:Name="Profile720MinTextBox" Grid.Column="1" />
                                    <TextBlock Grid.Row="1" Text="最大短边" VerticalAlignment="Center" />
                                    <TextBox x:Name="Profile720MaxTextBox" Grid.Row="1" Grid.Column="1" />
                                    <TextBlock Grid.Row="2" Text="视频码率" VerticalAlignment="Center" />
                                    <TextBox x:Name="Profile720BitrateTextBox" Grid.Row="2" Grid.Column="1" />
                                    <TextBlock Grid.Row="3" Text="音频码率" VerticalAlignment="Center" />
                                    <TextBox x:Name="Profile720AudioTextBox" Grid.Row="3" Grid.Column="1" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{DynamicResource DesktopPanelAltBrush}" CornerRadius="14" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="1080p" FontWeight="SemiBold" />
                                <CheckBox x:Name="Profile1080EnabledCheckBox" Content="启用" />
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                    <TextBlock Text="最小短边" VerticalAlignment="Center" />
                                    <TextBox x:Name="Profile1080MinTextBox" Grid.Column="1" />
                                    <TextBlock Grid.Row="1" Text="最大短边" VerticalAlignment="Center" />
                                    <TextBox x:Name="Profile1080MaxTextBox" Grid.Row="1" Grid.Column="1" />
                                    <TextBlock Grid.Row="2" Text="视频码率" VerticalAlignment="Center" />
                                    <TextBox x:Name="Profile1080BitrateTextBox" Grid.Row="2" Grid.Column="1" />
                                    <TextBlock Grid.Row="3" Text="音频码率" VerticalAlignment="Center" />
                                    <TextBox x:Name="Profile1080AudioTextBox" Grid.Row="3" Grid.Column="1" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{DynamicResource DesktopPanelAltBrush}" CornerRadius="14" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="2k+" FontWeight="SemiBold" />
                                <CheckBox x:Name="Profile2kEnabledCheckBox" Content="启用" />
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                    <TextBlock Text="最小短边" VerticalAlignment="Center" />
                                    <TextBox x:Name="Profile2kMinTextBox" Grid.Column="1" />
                                    <TextBlock Grid.Row="1" Text="最大短边" VerticalAlignment="Center" />
                                    <TextBox x:Name="Profile2kMaxTextBox" Grid.Row="1" Grid.Column="1" />
                                    <TextBlock Grid.Row="2" Text="视频码率" VerticalAlignment="Center" />
                                    <TextBox x:Name="Profile2kBitrateTextBox" Grid.Row="2" Grid.Column="1" />
                                    <TextBlock Grid.Row="3" Text="音频码率" VerticalAlignment="Center" />
                                    <TextBox x:Name="Profile2kAudioTextBox" Grid.Row="3" Grid.Column="1" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="2.2*,1*" ColumnSpacing="16">
                <StackPanel Spacing="16">
                    <Border Background="{DynamicResource DesktopPanelBrush}" CornerRadius="18" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="时序处理"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="裁切、静态变速和动态变速预设放在一起。"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource DesktopTextSecondaryBrush}" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                    <TextBlock Text="裁头" VerticalAlignment="Center" />
                                    <TextBox x:Name="TrimHeadTextBox" Grid.Column="1" />
                                    <TextBlock Grid.Row="1" Text="裁尾" VerticalAlignment="Center" />
                                    <TextBox x:Name="TrimTailTextBox" Grid.Row="1" Grid.Column="1" />
                                    <TextBlock Grid.Row="2" Text="静态变速" VerticalAlignment="Center" />
                                    <TextBox x:Name="SpeedPercentTextBox" Grid.Row="2" Grid.Column="1" />
                                    <CheckBox x:Name="DynamicSpeedEnabledCheckBox"
                                              Grid.Row="3"
                                              Grid.ColumnSpan="2"
                                              Content="启用动态变速" />
                                    <TextBlock Grid.Row="4" Text="动态预设" VerticalAlignment="Center" />
                                    <ComboBox x:Name="DynamicSpeedPresetComboBox"
                                              Grid.Row="4"
                                              Grid.Column="1" />
                                </Grid>

                                <Grid Grid.Column="1"
                                      ColumnDefinitions="Auto,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                      ColumnSpacing="10"
                                      RowSpacing="8">
                                    <TextBlock Text="开头时长" VerticalAlignment="Center" />
                                    <TextBox x:Name="DynamicSpeedHeadSecondsTextBox" Grid.Column="1" />
                                    <TextBlock Grid.Row="1" Text="开头变速" VerticalAlignment="Center" />
                                    <TextBox x:Name="DynamicSpeedHeadPercentTextBox" Grid.Row="1" Grid.Column="1" />
                                    <TextBlock Grid.Row="2" Text="中间变速" VerticalAlignment="Center" />
                                    <TextBox x:Name="DynamicSpeedMiddlePercentTextBox" Grid.Row="2" Grid.Column="1" />
                                    <TextBlock Grid.Row="3" Text="结尾时长" VerticalAlignment="Center" />
                                    <TextBox x:Name="DynamicSpeedTailSecondsTextBox" Grid.Row="3" Grid.Column="1" />
                                    <TextBlock Grid.Row="4" Text="结尾变速" VerticalAlignment="Center" />
                                    <TextBox x:Name="DynamicSpeedTailPercentTextBox" Grid.Row="4" Grid.Column="1" />
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource DesktopPanelBrush}" CornerRadius="18" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="抽帧处理"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="抽帧会在动态变速之后执行。"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource DesktopTextSecondaryBrush}" />
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                <CheckBox x:Name="FrameSamplingEnabledCheckBox"
                                          Grid.ColumnSpan="2"
                                          Content="启用抽帧" />
                                <TextBlock Grid.Row="1" Text="抽帧模式" VerticalAlignment="Center" />
                                <ComboBox x:Name="FrameSamplingModeComboBox"
                                          Grid.Row="1"
                                          Grid.Column="1" />
                                <TextBlock Grid.Row="2" Text="抽帧间隔" VerticalAlignment="Center" />
                                <TextBox x:Name="FrameSamplingIntervalTextBox"
                                         Grid.Row="2"
                                         Grid.Column="1" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource DesktopPanelBrush}" CornerRadius="18" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="水印文字"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="水印文字、字号、位置和边距统一管理。"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource DesktopTextSecondaryBrush}" />
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                <CheckBox x:Name="WatermarkEnabledCheckBox"
                                          Grid.ColumnSpan="2"
                                          Content="启用水印文字" />
                                <TextBlock Grid.Row="1" Text="水印文字" VerticalAlignment="Center" />
                                <TextBox x:Name="WatermarkTextTextBox"
                                         Grid.Row="1"
                                         Grid.Column="1" />
                                <TextBlock Grid.Row="2" Text="水印字号" VerticalAlignment="Center" />
                                <TextBox x:Name="WatermarkFontSizeTextBox"
                                         Grid.Row="2"
                                         Grid.Column="1" />
                                <TextBlock Grid.Row="3" Text="水印位置" VerticalAlignment="Center" />
                                <ComboBox x:Name="WatermarkPositionComboBox"
                                          Grid.Row="3"
                                          Grid.Column="1" />
                                <TextBlock x:Name="WatermarkMarginXLabel"
                                           Grid.Row="4"
                                           Text="距右边"
                                           VerticalAlignment="Center" />
                                <TextBox x:Name="WatermarkMarginXTextBox"
                                         Grid.Row="4"
                                         Grid.Column="1" />
                                <TextBlock Grid.Row="5" Text="距上边" VerticalAlignment="Center" />
                                <TextBox x:Name="WatermarkMarginYTextBox"
                                         Grid.Row="5"
                                         Grid.Column="1" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="16">
                    <Border Background="{DynamicResource DesktopPanelBrush}" CornerRadius="18" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="画面构图"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="与画面尺寸、裁边和前景大小相关的参数集中在这里。"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource DesktopTextSecondaryBrush}" />
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                <TextBlock Text="输出宽度" VerticalAlignment="Center" />
                                <TextBox x:Name="OutputWidthTextBox" Grid.Column="1" />
                                <TextBlock Grid.Row="1" Text="输出高度" VerticalAlignment="Center" />
                                <TextBox x:Name="OutputHeightTextBox" Grid.Row="1" Grid.Column="1" />
                                <TextBlock Grid.Row="2" Text="上下裁边" VerticalAlignment="Center" />
                                <TextBox x:Name="CropHeightPercentTextBox" Grid.Row="2" Grid.Column="1" />
                                <TextBlock Grid.Row="3" Text="左右裁边" VerticalAlignment="Center" />
                                <TextBox x:Name="CropWidthPercentTextBox" Grid.Row="3" Grid.Column="1" />
                                <TextBlock Grid.Row="4" Text="前景放大" VerticalAlignment="Center" />
                                <TextBox x:Name="ForegroundZoomPercentTextBox" Grid.Row="4" Grid.Column="1" />
                                <TextBlock Grid.Row="5" Text="前景宽度" VerticalAlignment="Center" />
                                <TextBox x:Name="PipWidthPercentTextBox" Grid.Row="5" Grid.Column="1" />
                                <TextBlock Grid.Row="6" Text="前景高度" VerticalAlignment="Center" />
                                <TextBox x:Name="PipHeightPercentTextBox" Grid.Row="6" Grid.Column="1" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource DesktopPanelBrush}" CornerRadius="18" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="模板预览"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="预览会随着裁边、放大、水印和前景尺寸变化即时刷新。"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource DesktopTextSecondaryBrush}" />
                            <Viewbox Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Top">
                                <Canvas x:Name="PreviewCanvas"
                                        Width="1080"
                                        Height="1920"
                                        Background="#F5F7FB">
                                    <Border x:Name="PreviewFrameBorder"
                                            Width="1080"
                                            Height="1920"
                                            Background="#D7E2EF"
                                            BorderBrush="#91A4B8"
                                            BorderThickness="2" />
                                    <Border x:Name="PreviewForegroundBorder"
                                            Width="1080"
                                            Height="1920"
                                            Background="#FFFFFF"
                                            BorderBrush="#334155"
                                            BorderThickness="4" />
                                    <shapes:Rectangle x:Name="PreviewCropRectangle"
                                                      Stroke="#EF4444"
                                                      StrokeThickness="4"
                                                      StrokeDashArray="14,10"
                                                      Fill="#00FFFFFF" />
                                    <shapes:Rectangle x:Name="PreviewZoomRectangle"
                                                      Stroke="#F97316"
                                                      StrokeThickness="4"
                                                      StrokeDashArray="14,10"
                                                      Fill="#00FFFFFF" />
                                    <TextBlock x:Name="PreviewWatermarkTextBlock"
                                               Foreground="#F8FAFC"
                                               FontWeight="Bold"
                                               IsVisible="False" />
                                    <TextBlock x:Name="PreviewDescriptionTextBlock"
                                               Foreground="#475569"
                                               FontSize="40"
                                               Text="Portrait preview" />
                                </Canvas>
                            </Viewbox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="StatusTextBlock"
                       Foreground="{DynamicResource DesktopTextSecondaryBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
